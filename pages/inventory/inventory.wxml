<view class="container">
  <view class="section-title">库存管理</view>
  <view class="tm-card form-card">
    <view class="form-grid">
      <view class="field"><text class="label">商品分类</text><input placeholder="如：天猫爆款" value="{{form.category}}" data-field="category" bindinput="onInput" /></view>
      <view class="field"><text class="label">商品名称</text><input placeholder="请输入商品名称" value="{{form.name}}" data-field="name" bindinput="onInput" /></view>
      <view class="field"><text class="label">商品规格</text><input placeholder="颜色 / 尺码 / 型号" value="{{form.spec}}" data-field="spec" bindinput="onInput" /></view>
      <view class="field"><text class="label">商品单价</text><input type="digit" placeholder="0.00" value="{{form.unitPrice}}" data-field="unitPrice" bindinput="onInput" /></view>
      <view class="field"><text class="label">在库数量</text><input type="number" placeholder="0" value="{{form.stock}}" data-field="stock" bindinput="onInput" /></view>
      <view class="field"><text class="label">供应商</text><input placeholder="请输入供应商" value="{{form.supplier}}" data-field="supplier" bindinput="onInput" /></view>
      <view class="field"><text class="label">预警数量</text><input type="number" placeholder="0" value="{{form.warningQty}}" data-field="warningQty" bindinput="onInput" /></view>
      <view class="field"><text class="label">备注</text><textarea placeholder="商品备注" value="{{form.remark}}" data-field="remark" bindinput="onInput" /></view>
    </view>
    <view class="btn-row"><button class="tm-btn" bindtap="saveRecord">{{editingId ? '保存修改' : '添加商品'}}</button><button class="tm-btn secondary" bindtap="resetForm">清空</button></view>
  </view>
  <view class="toolbar"><button class="tm-btn secondary" bindtap="toggleSelectAll">{{allSelected ? '取消全选' : '全选'}}</button><button class="tm-btn dark" bindtap="deleteSelected">一键删除所选</button></view>
  <view wx:if="{{records.length === 0}}" class="tm-card empty">暂无商品，请先添加库存档案</view>
  <view class="tm-card record-card" wx:for="{{records}}" wx:key="id">
    <view class="record-head"><label class="checkbox-line"><checkbox checked="{{selectedMap[item.id]}}" data-id="{{item.id}}" bindtap="toggleSelect" /> <view><view class="record-title">{{item.name}}</view><view class="record-subtitle">{{item.category}} · {{item.spec}}</view></view></label><text class="action-link" data-id="{{item.id}}" bindtap="editRecord">编辑</text></view>
    <view class="record-grid"><view class="kv">单价 <text>¥{{item.unitPrice}}</text></view><view class="kv">在库 <text>{{item.stock}}</text></view><view class="kv">供应商 <text>{{item.supplier}}</text></view><view class="kv">预警 <text>{{item.warningQty}}</text></view><view class="kv">备注 <text>{{item.remark}}</text></view></view>
  </view>
</view>
<app-nav current="inventory" />
