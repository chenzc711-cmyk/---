.login-page {
  min-height: 100vh;
  padding: 110rpx 40rpx;
  box-sizing: border-box;
  background: radial-gradient(circle at 20% 8%, rgba(255, 255, 255, 0.9), transparent 30%), linear-gradient(145deg, #ff0036 0%, #ff5a3d 48%, #111827 100%);
}
.login-card {
  padding: 58rpx 38rpx;
  border-radius: 38rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 30rpx 80rpx rgba(17, 24, 39, 0.22);
  text-align: center;
}
.brand-mark {
  width: 110rpx;
  height: 110rpx;
  line-height: 110rpx;
  border-radius: 32rpx;
  margin: 0 auto 28rpx;
  color: #fff;
  font-size: 58rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #ff0036, #ff7a00);
}
.title {
  font-size: 44rpx;
  font-weight: 900;
  color: #111827;
}
.subtitle {
  color: #6b7280;
  margin: 16rpx 0 44rpx;
}
.code-field {
  text-align: left;
  margin-bottom: 28rpx;
}
.tips {
  margin-top: 22rpx;
  color: #9ca3af;
  font-size: 24rpx;
}
