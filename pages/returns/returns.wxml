<view class="container"><view class="section-title">退货入库管理</view>
  <view class="tm-card filter-card"><view class="field"><text class="label">按退货日期筛选</text><picker mode="date" value="{{filterDate}}" bindchange="onFilterDate"><view>{{filterDate || '选择日期查看退货记录'}}</view></picker></view><view class="btn-row"><button class="tm-btn secondary" bindtap="clearFilter">显示全部</button></view></view>
  <view class="tm-card form-card"><view class="form-grid">
    <view class="field"><text class="label">退货日期</text><picker mode="date" value="{{form.returnDate}}" data-field="returnDate" bindchange="onDateChange"><view>{{form.returnDate || '选择日期'}}</view></picker></view>
    <view class="field"><text class="label">订单号</text><input value="{{form.orderNo}}" data-field="orderNo" bindinput="onInput" placeholder="订单号" /></view>
    <view class="field"><text class="label">物流公司</text><input value="{{form.logisticsCompany}}" data-field="logisticsCompany" bindinput="onInput" placeholder="物流公司" /></view>
    <view class="field"><text class="label">物流单号</text><input value="{{form.trackingNo}}" data-field="trackingNo" bindinput="onInput" placeholder="物流单号" /></view>
    <view class="field"><text class="label">商品名称</text><input value="{{form.name}}" data-field="name" bindinput="onInput" placeholder="商品名称" /></view>
    <view class="field"><text class="label">商品规格</text><input value="{{form.spec}}" data-field="spec" bindinput="onInput" placeholder="商品规格" /></view>
    <view class="field"><text class="label">数量</text><input type="number" value="{{form.quantity}}" data-field="quantity" bindinput="onInput" placeholder="0" /></view>
    <view class="field"><text class="label">货物状态</text><input value="{{form.status}}" data-field="status" bindinput="onInput" placeholder="可二次销售 / 破损" /></view>
    <view class="field"><text class="label">备注</text><textarea value="{{form.remark}}" data-field="remark" bindinput="onInput" placeholder="备注" /></view>
  </view><view class="btn-row"><button class="tm-btn" bindtap="saveRecord">{{editingId ? '保存修改' : '添加退货入库信息'}}</button><button class="tm-btn secondary" bindtap="resetForm">清空</button></view></view>
  <view class="toolbar"><button class="tm-btn secondary" bindtap="toggleSelectAll">{{allSelected ? '取消全选' : '全选'}}</button><button class="tm-btn dark" bindtap="deleteSelected">一键删除所选</button></view>
  <view wx:if="{{records.length === 0}}" class="tm-card empty">暂无退货入库记录</view>
  <view class="tm-card record-card" wx:for="{{records}}" wx:key="id"><view class="record-head"><label class="checkbox-line"><checkbox checked="{{selectedMap[item.id]}}" data-id="{{item.id}}" bindtap="toggleSelect"/><view><view class="record-title">{{item.name}}</view><view class="record-subtitle">{{item.returnDate}} · {{item.orderNo}}</view></view></label><text class="action-link" data-id="{{item.id}}" bindtap="editRecord">编辑</text></view><view class="record-grid"><view class="kv">规格 <text>{{item.spec}}</text></view><view class="kv">数量 <text>{{item.quantity}}</text></view><view class="kv">物流 <text>{{item.logisticsCompany}}</text></view><view class="kv">单号 <text>{{item.trackingNo}}</text></view><view class="kv">状态 <text>{{item.status}}</text></view><view class="kv">备注 <text>{{item.remark}}</text></view></view></view>
</view>
