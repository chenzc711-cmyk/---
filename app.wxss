page {
  min-height: 100%;
  background: #f6f7fb;
  color: #1f2937;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  font-size: 28rpx;
}
.container {
  padding: 24rpx;
  box-sizing: border-box;
}
.tm-card {
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 16rpx 44rpx rgba(255, 0, 54, 0.08);
  border: 1rpx solid rgba(255, 0, 54, 0.08);
  margin-bottom: 24rpx;
  overflow: hidden;
}
.tm-gradient {
  background: linear-gradient(135deg, #ff0036 0%, #ff5a3d 48%, #111827 120%);
  color: #ffffff;
}
.section-title {
  font-size: 34rpx;
  font-weight: 700;
  margin: 8rpx 0 20rpx;
  display: flex;
  align-items: center;
}
.section-title::before {
  content: '';
  width: 8rpx;
  height: 34rpx;
  border-radius: 999rpx;
  background: #ff0036;
  margin-right: 14rpx;
}
.form-card {
  padding: 24rpx;
}
.form-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
}
.field {
  background: #f9fafb;
  border-radius: 18rpx;
  border: 1rpx solid #eef0f5;
  padding: 16rpx 18rpx;
}
.label {
  display: block;
  color: #6b7280;
  font-size: 24rpx;
  margin-bottom: 10rpx;
}
input, picker, textarea {
  width: 100%;
  min-height: 46rpx;
  color: #111827;
  font-size: 28rpx;
  box-sizing: border-box;
}
textarea {
  height: 90rpx;
}
.placeholder {
  color: #a3a8b3;
}
.btn-row {
  display: flex;
  gap: 18rpx;
  margin-top: 22rpx;
}
.tm-btn {
  flex: 1;
  border: 0;
  border-radius: 999rpx;
  height: 82rpx;
  line-height: 82rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  background: linear-gradient(90deg, #ff0036, #ff6a00);
  box-shadow: 0 12rpx 26rpx rgba(255, 0, 54, 0.22);
}
.tm-btn.secondary {
  color: #ff0036;
  background: #fff0f3;
  box-shadow: none;
}
.tm-btn.dark {
  background: #111827;
  box-shadow: none;
}
.toolbar {
  display: flex;
  gap: 16rpx;
  align-items: center;
  margin: 18rpx 0;
}
.toolbar .tm-btn {
  height: 68rpx;
  line-height: 68rpx;
  font-size: 25rpx;
}
.filter-card {
  padding: 20rpx;
}
.record-card {
  padding: 22rpx;
  position: relative;
}
.record-head {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: flex-start;
  margin-bottom: 16rpx;
}
.record-title {
  font-weight: 700;
  font-size: 30rpx;
}
.record-subtitle {
  color: #6b7280;
  font-size: 24rpx;
  margin-top: 6rpx;
}
.record-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx 18rpx;
}
.kv {
  color: #6b7280;
  font-size: 24rpx;
}
.kv text {
  color: #111827;
  font-weight: 600;
}
.badge {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #ff0036;
  background: #fff0f3;
  font-size: 23rpx;
  font-weight: 700;
}
.checkbox-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.empty {
  text-align: center;
  color: #9ca3af;
  padding: 56rpx 20rpx;
}
.action-link {
  color: #ff0036;
  font-weight: 700;
  font-size: 25rpx;
}
